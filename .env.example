# App
APP_NAME=portfolio-backend
PORT=8080
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
# optional: use bcrypt hash instead of plain password
ADMIN_PASSWORD_HASH=
AUTH_TOKEN_TTL_MINUTES=720

# Database (MongoDB)
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=password
MONGO_URI=mongodb://admin:password@localhost:27017/?authSource=admin
MONGO_DB=portfolio

# Vector DB (pgvector)
VECTOR_DB_HOST=localhost
VECTOR_DB_PORT=5433
VECTOR_DB_USER=postgres
VECTOR_DB_PASSWORD=postgres
VECTOR_DB_NAME=portfolio_vector
VECTOR_DB_SSLMODE=disable
VECTOR_DB_URL=postgres://postgres:postgres@localhost:5433/portfolio_vector?sslmode=disable

# MinIO
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=password
MINIO_ENDPOINT=localhost:9000
MINIO_BUCKET=portfolio
MINIO_USE_SSL=false
MINIO_PUBLIC_BASE_URL=http://localhost:9000

# Redis (chat memory)
REDIS_PASSWORD=password
REDIS_URL=redis://:password@localhost:6379/0
REDIS_KEY_PREFIX=portfolio:chat:
REDIS_TIMEOUT_SECONDS=5
MEMORY_STORE=redis

# CORS
CORS_ALLOW_ORIGINS=http://localhost:3000
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Origin,Content-Type,Accept,Authorization
CORS_ALLOW_CREDENTIALS=true

# Go API -> AI service
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_TIMEOUT_SECONDS=180

# AI provider switch (used by ai-service)
API_SERVICE=openai

# OpenAI-compatible config
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_TIMEOUT_SECONDS=60

# Ollama config (used when API_SERVICE=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:1b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TIMEOUT_SECONDS=300

# Optional headers (useful for OpenRouter)
OPENROUTER_HTTP_REFERER=
OPENROUTER_X_TITLE=portfolio-backend

# AI persona/system prompt
AI_SYSTEM_PROMPT="You are Peerapat. Style: practical, opinionated, dev mindset."
MEMORY_MAX_TURNS=12
